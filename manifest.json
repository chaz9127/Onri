{
  "manifest_version": 3,
  "name": "Onri",
  "version": "2.0.0",
  "description": "Choose your animated browser pet to keep you company while you doom scroll the internet.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "onri"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sprites/dino/*/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
