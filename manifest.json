{
  "manifest_version": 3,
  "name": "onri",
  "version": "1.0.0",
  "description": "An animated sprite that lives at the bottom of your browser.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "onri"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sprites/*/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
